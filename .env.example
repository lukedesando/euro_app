DB_ENGINE=mysql
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_HOST=your_database_host
DB_NAME=eurovision_db

APP_HOST=0.0.0.0
APP_PORT=5000
API_HOST=your_lan_ip_or_hostname
API_PORT=5000

